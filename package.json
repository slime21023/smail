{
	"name": "smail",
	"version": "0.1.0-alpha.0",
	"description": "Embeddable EDM/email template editor library for Svelte, powered by Ark UI and MJML",
	"license": "MIT",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run prepack",
		"preview": "vite preview",
		"test": "vitest run",
		"test:watch": "vitest",
		"e2e": "node scripts/e2e.mjs",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"peerDependencies": {
		"mjml-browser": "^4.15.0",
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"happy-dom": "^20.10.6",
		"mjml-browser": "4.18.0",
		"playwright-core": "^1.61.1",
		"publint": "^0.3.21",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.10"
	},
	"keywords": [
		"svelte",
		"mjml",
		"email",
		"edm",
		"newsletter",
		"editor",
		"email-builder"
	],
	"dependencies": {
		"@ark-ui/svelte": "^5.22.1",
		"svelte-dnd-action": "^0.9.74"
	}
}
